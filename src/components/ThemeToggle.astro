<button
  id="theme-toggle"
  class="fixed top-6 right-6 p-2 rounded-full bg-base-200 hover:bg-base-300 transition-colors z-50 shadow-sm"
  aria-label="Toggle Dark Mode"
>
  <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <!-- Sun icon for when it is currently dark -->
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <!-- Moon icon for when it is currently light -->
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script>
  // Add dark mode toggle script
  const themeToggleButton = document.getElementById("theme-toggle");

  themeToggleButton?.addEventListener("click", () => {
    const htmlNode = document.documentElement;
    const isDark = htmlNode.classList.contains("dark");
    
    if (isDark) {
      htmlNode.classList.remove("dark");
      htmlNode.setAttribute("data-theme", "lofi");
      localStorage.setItem("theme", "light");
    } else {
      htmlNode.classList.add("dark");
      htmlNode.setAttribute("data-theme", "black");
      localStorage.setItem("theme", "dark");
    }
  });
</script>
