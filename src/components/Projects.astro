---
import projects from "../data/projects.json";
---

<div class="space-y-12 w-full py-12">
  <div class="flex flex-col items-center justify-center space-y-4 text-center">
    <div class="space-y-2">
      <h2 class="text-3xl font-bold tracking-tighter sm:text-5xl">Projects</h2>
      <p
        class="text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed"
      >
        I like building things. Here are some of my <span class="font-bold"
          >favorites</span
        >.
      </p>
    </div>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-20 max-w-4xl mx-auto px-4 md:px-0"
  >
    {
      projects.projects.map((project) => (
        <div class="relative group/card-wrapper">
          {/* Floating Images */}
          {project.floatingImages && (
            <div class="absolute inset-0 pointer-events-none overflow-visible" style="perspective: 1200px; z-index: 20;">
              {Object.entries(project.floatingImages).map(([key, img]) => (
                <img
                  src={img.src}
                  alt=""
                  class:list={[
                    "absolute transition-all duration-700 ease-out group-hover/card-wrapper:scale-110",
                    `floating-img-${key}`
                  ]}
                  style={`
                    width: ${img.width};
                    left: ${img.x};
                    top: ${img.y};
                    z-index: ${img.zIndex};
                    --w: ${img.width};
                    --left: ${img.x};
                    --top: ${img.y};
                    --z: ${img.z};
                    --mw: ${img.width};
                    --mleft: ${img.mobile?.x || img.x};
                    --mtop: ${img.mobile?.y || img.y};
                  `}
                />
              ))}
            </div>
          )}

          <a
            href={project.href || undefined}
            target={project.href ? "_blank" : undefined}
            rel={project.href ? "noopener noreferrer" : undefined}
            class:list={[
              "group relative flex flex-col rounded-2xl border border-gray-200 bg-white overflow-hidden transition-all duration-300 z-10",
              project.href
                ? "hover:shadow-2xl hover:-translate-y-2 cursor-pointer"
                : "opacity-60 cursor-default",
            ]}
          >
            {/* Image */}
            {project.image ? (
              <div class="relative w-full aspect-video overflow-hidden bg-gradient-to-br from-gray-100 to-gray-200">
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
              </div>
            ) : (
              <div class="w-full aspect-video bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                <svg
                  class="w-16 h-16 text-gray-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                  />
                </svg>
              </div>
            )}

            {/* Content */}
            <div class="flex flex-col flex-1 p-5 space-y-3">
              <div class="flex items-start justify-between gap-2">
                <h3
                  class="text-lg font-bold text-gray-900 group-hover:text-primary transition-colors"
                >
                  {project.title}
                </h3>
                {project.active && project.href && (
                  <span class="flex-shrink-0 mt-1">
                    <svg
                      class="w-4 h-4 text-gray-400 group-hover:text-primary transition-colors transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 17L17 7M17 7H7M17 7v10"
                      />
                    </svg>
                  </span>
                )}
              </div>

              <p class="text-sm text-gray-600 leading-relaxed flex-1">
                {project.description}
              </p>

              {/* Tech Tags */}
              {project.technologies.length > 0 && (
                <div class="flex flex-wrap gap-1.5 pt-1">
                  {project.technologies.map((tech) => (
                    <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-gray-100 text-gray-700 border border-gray-200">
                      {tech}
                    </span>
                  ))}
                </div>
              )}

              {/* Links */}
              {project.links.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-2 border-t border-gray-100">
                  {project.links.map((link) => (
                    <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 group-hover:text-primary transition-colors">
                      {link.type === "GitHub" && (
                        <svg
                          class="w-3.5 h-3.5"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                      )}
                      {link.type}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        </div>
      ))
    }
  </div>
</div>

<style is:global>
  .text-muted-foreground {
    color: #6b7280;
  }

  [class*="floating-img-"] {
    width: var(--w) !important;
    left: var(--left) !important;
    top: var(--top) !important;
    transform: translate3d(-50%, -50%, var(--z)) !important;
  }

  @media (max-width: 640px) {
    [class*="floating-img-"] {
      width: var(--mw) !important;
      left: var(--mleft) !important;
      top: var(--mtop) !important;
    }
  }
</style>
