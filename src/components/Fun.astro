---
// Import achievements data
import data from '../data/fun_activity.json';

// Use custom achievements if provided, otherwise use imported data
const finalAchievements = data.fun || [];

// Helper functions for navigation
const getPrevSlideIndex = (currentIndex:number, totalSlides: number) => {
  return currentIndex === 0 ? totalSlides - 1 : currentIndex - 1;
};

const getNextSlideIndex = (currentIndex:number, totalSlides: number) => {
  return currentIndex === totalSlides - 1 ? 0 : currentIndex + 1;
};
---

<div class="relative w-full">
  <div class="space-y-12 w-full py-12">
    <div class="flex flex-col items-center justify-center space-y-4 text-center">
      <div class="space-y-2">
        <h2 class="text-3xl font-bold tracking-tighter sm:text-5xl">
          Fun Events & Activities
        </h2>
        <p class="text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed">
          {finalAchievements.length === 0 
            ? "No achievements to display yet."
            : "During my time in university, I attended 4 hackathons and was a part of multiple club events and activities. I like to keep exploring and learning new things."
          }
        </p>
      </div>
    </div>
  </div>

  {finalAchievements.length > 0 && (
    <div class="bento-grid grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3 sm:gap-4">
      {finalAchievements.map((achievement: any, index: number) => {
        // Repeat bento pattern every 6 items
        const pos = index % 6;
        let gridClasses = "relative group overflow-hidden rounded-2xl bg-muted transition-all duration-300 hover:scale-[1.02] hover:shadow-xl w-full h-full";
        
        if (pos === 0) {
          gridClasses += " col-span-2 lg:col-span-4 lg:row-span-2"; // Large feature card
        } else if (pos === 1) {
          gridClasses += " col-span-1 lg:col-span-2 lg:row-span-1"; // Standard card
        } else if (pos === 2) {
          gridClasses += " col-span-1 lg:col-span-2 lg:row-span-2"; // Tall card on desktop
        } else {
          gridClasses += " col-span-1 lg:col-span-2 lg:row-span-1"; // Standard card
        }

        return (
          <div class={gridClasses}>
            <img
              src={achievement.image}
              alt={achievement.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            
            <!-- Overlay with achievement info -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4 sm:p-6 text-white">
              <div class="transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                <h3 class="text-base sm:text-lg font-bold mb-1 leading-tight">
                  {achievement.title}
                </h3>
                <div class="flex flex-wrap items-center gap-1 sm:gap-2 text-white/80 text-[10px] sm:text-xs mb-1">
                  <span>{achievement.dates}</span>
                  <span class="hidden sm:inline w-1 h-1 bg-white/40 rounded-full"></span>
                  <span>{achievement.location}</span>
                </div>
                {achievement.description && (
                  <p class="text-white/70 text-[10px] sm:text-xs mt-2 line-clamp-1 sm:line-clamp-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    {achievement.description}
                  </p>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  )}
</div>

<style>
  .text-muted-foreground {
    color: #6b7280;
  }
  .bento-grid {
    grid-auto-rows: 180px;
  }
  @media (min-width: 768px) {
    .bento-grid {
      grid-auto-rows: 250px;
    }
  }
  @media (min-width: 1024px) {
    .bento-grid {
      grid-auto-rows: 280px;
    }
  }

</style>