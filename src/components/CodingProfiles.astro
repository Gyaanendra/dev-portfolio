---

---

<div class="w-full py-12">
  <div
    class="flex flex-col items-center justify-center space-y-4 text-center mb-8"
  >
    <h2
      class="text-3xl font-bold tracking-tighter sm:text-5xl text-gray-900"
    >
      Coding Profiles
    </h2>
    <p class="text-muted-foreground md:text-lg text-gray-700">
      My activity across different platforms.
    </p>
  </div>

  <div class="w-full mx-auto flex flex-col items-center">
    <div class="w-full flex-col flex items-center mb-4">
      <h3 class="text-xl font-bold mb-4 text-gray-900">
        GitHub Contributions
      </h3>
      <div class="w-full overflow-x-auto pb-4 custom-scrollbar">
        <img
          src="https://ghchart.rshah.org/Gyaanendra"
          alt="Gyanendra's Github Chart"
          class="min-w-[700px] w-full max-w-4xl mx-auto object-contain transition-all duration-300 px-4"
        />
      </div>
    </div>
  </div>
</div>

<style>
  /* Optional custom scrollbar for horizontal scrolling on tiny phones if needed */
  .custom-scrollbar::-webkit-scrollbar {
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #f1f1f1; 
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #c1c1c1; 
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8; 
  }
</style>
